{
  "name": "wemepet-platform",
  "version": "2.0.0",
  "private": true,
  "description": "WemePet hard-reset production platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @wemepet/api",
    "dev:web": "npm run dev -w @wemepet/web",
    "build:api": "npm run build -w @wemepet/api",
    "build:web": "npm run build -w @wemepet/web",
    "start:api": "npm run start:prod -w @wemepet/api",
    "start:web": "npm run start -w @wemepet/web",
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "npm run format --workspaces"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
