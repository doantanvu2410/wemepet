generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  USER
  MODERATOR
  ADMIN
}

enum PostKind {
  STATUS
  KOI_PROFILE
}

enum PostStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum MediaKind {
  IMAGE
  VIDEO
  CERTIFICATE
  AVATAR
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum KoiStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum NotificationType {
  POST_LIKE
  POST_COMMENT
  COMMENT_REPLY
  FOLLOW
  TRANSFER_REQUEST
  TRANSFER_ACCEPTED
  TRANSFER_REJECTED
  KOI_APPROVED
  KOI_REJECTED
  SYSTEM
}

enum ActorType {
  USER
  SYSTEM
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum UploadTarget {
  POST
  KOI
  AVATAR
}

model User {
  id               String       @id @default(uuid()) @db.Uuid
  authSubject      String       @unique @map("auth_subject")
  email            String       @unique
  passwordHash     String?      @map("password_hash")
  displayName      String       @map("display_name")
  avatarUrl        String?      @map("avatar_url")
  bio              String?
  isPrivate        Boolean      @default(false) @map("is_private")
  emailVerifiedAt  DateTime?    @map("email_verified_at")
  lastLoginAt      DateTime?    @map("last_login_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  bookmarks        Bookmark[]
  followerLinks    Follow[]     @relation("FollowFollowee")
  followingLinks   Follow[]     @relation("FollowFollower")
  roles            UserRole[]   @relation("UserRoleUser")
  assignedRoles    UserRole[]   @relation("UserRoleAssigner")
  koiOwned         Koi[]        @relation("KoiOwner")
  koiApproved      Koi[]        @relation("KoiApprover")
  transferFrom     Transfer[]   @relation("TransferFrom")
  transferTo       Transfer[]   @relation("TransferTo")
  notifications    Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")
  notificationStat NotificationStat?
  mediaUploads     MediaUploadIntent[]
  auditLogs        AuditLog[]

  @@index([createdAt])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  code        RoleCode  @unique
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") @db.Uuid
  user       User     @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner   User?    @relation("UserRoleAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Post {
  id           String      @id @default(uuid()) @db.Uuid
  authorId     String      @map("author_id") @db.Uuid
  kind         PostKind    @default(STATUS)
  status       PostStatus  @default(ACTIVE)
  visibility   Visibility  @default(PUBLIC)
  bodyText     String?     @map("body_text") @db.Text
  likeCount    Int         @default(0) @map("like_count")
  commentCount Int         @default(0) @map("comment_count")
  shareCount   Int         @default(0) @map("share_count")
  bookmarkCount Int        @default(0) @map("bookmark_count")
  publishedAt  DateTime    @default(now()) @map("published_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  koiId        String?     @unique @map("koi_id") @db.Uuid
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media        PostMedia[]
  comments     Comment[]
  likes        Like[]
  bookmarks    Bookmark[]
  koi          Koi?        @relation("KoiProfilePost", fields: [koiId], references: [id], onDelete: SetNull)

  @@index([authorId, publishedAt])
  @@index([status, publishedAt])
  @@index([koiId])
  @@map("posts")
}

model PostMedia {
  id          String    @id @default(uuid()) @db.Uuid
  postId      String    @map("post_id") @db.Uuid
  kind        MediaKind
  url         String
  thumbnailUrl String?  @map("thumbnail_url")
  mimeType    String?   @map("mime_type")
  sizeBytes   Int?      @map("size_bytes")
  width       Int?
  height      Int?
  durationSec Int?      @map("duration_sec")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("post_media")
}

model Comment {
  id              String        @id @default(uuid()) @db.Uuid
  postId          String        @map("post_id") @db.Uuid
  authorId        String        @map("author_id") @db.Uuid
  parentCommentId String?       @map("parent_comment_id") @db.Uuid
  rootCommentId   String?       @map("root_comment_id") @db.Uuid
  depth           Int           @default(0)
  body            String        @db.Text
  status          CommentStatus @default(ACTIVE)
  likeCount       Int           @default(0) @map("like_count")
  replyCount      Int           @default(0) @map("reply_count")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?      @relation("CommentTree", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[]     @relation("CommentTree")
  rootComment     Comment?      @relation("CommentRoot", fields: [rootCommentId], references: [id], onDelete: SetNull)
  threadComments  Comment[]     @relation("CommentRoot")

  @@index([postId, createdAt])
  @@index([parentCommentId])
  @@index([rootCommentId])
  @@map("comments")
}

model Like {
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Bookmark {
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("bookmarks")
}

model Follow {
  followerId String   @map("follower_id") @db.Uuid
  followeeId String   @map("followee_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  follower   User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User     @relation("FollowFollowee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
  @@map("follows")
}

model Koi {
  id               String      @id @default(uuid()) @db.Uuid
  ownerUserId      String      @map("owner_user_id") @db.Uuid
  name             String
  variety          String?
  gender           String?
  birthDate        DateTime?   @map("birth_date") @db.Date
  sizeCm           Decimal?    @map("size_cm") @db.Decimal(6, 2)
  description      String?     @db.Text
  lineage          String?     @db.Text
  certificateCode  String?     @map("certificate_code")
  status           KoiStatus   @default(PENDING)
  isTransferLocked Boolean     @default(false) @map("is_transfer_locked")
  lockVersion      Int         @default(0) @map("lock_version")
  approvedByUserId String?     @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?   @map("approved_at")
  rejectedReason   String?     @map("rejected_reason")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")
  owner            User        @relation("KoiOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  approvedBy       User?       @relation("KoiApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  media            KoiMedia[]
  profilePost      Post?       @relation("KoiProfilePost")
  transfers        Transfer[]

  @@index([ownerUserId, createdAt])
  @@index([status, createdAt])
  @@map("koi")
}

model KoiMedia {
  id           String    @id @default(uuid()) @db.Uuid
  koiId        String    @map("koi_id") @db.Uuid
  kind         MediaKind
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  koi          Koi       @relation(fields: [koiId], references: [id], onDelete: Cascade)

  @@index([koiId, sortOrder])
  @@map("koi_media")
}

model Transfer {
  id             String         @id @default(uuid()) @db.Uuid
  koiId          String         @map("koi_id") @db.Uuid
  fromUserId     String         @map("from_user_id") @db.Uuid
  toUserId       String         @map("to_user_id") @db.Uuid
  status         TransferStatus @default(PENDING)
  note           String?
  reason         String?
  requestedAt    DateTime       @default(now()) @map("requested_at")
  decidedAt      DateTime?      @map("decided_at")
  cancelledAt    DateTime?      @map("cancelled_at")
  expiresAt      DateTime?      @map("expires_at")
  idempotencyKey String?        @unique @map("idempotency_key")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  koi            Koi            @relation(fields: [koiId], references: [id], onDelete: Restrict)
  fromUser       User           @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser         User           @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Restrict)

  @@index([koiId, status])
  @@index([toUserId, status, requestedAt])
  @@index([fromUserId, requestedAt])
  @@map("transfers")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  actorUserId String?          @map("actor_user_id") @db.Uuid
  type        NotificationType
  entityType  String           @map("entity_type")
  entityId    String?          @map("entity_id")
  groupKey    String?          @map("group_key")
  metadata    Json
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorUser   User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([groupKey])
  @@map("notifications")
}

model NotificationStat {
  userId      String   @id @map("user_id") @db.Uuid
  unreadCount Int      @default(0) @map("unread_count")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_stats")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorType  ActorType @default(USER) @map("actor_type")
  action     String
  entityType String    @map("entity_type")
  entityId   String?   @map("entity_id")
  requestId  String?   @map("request_id")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  metadata   Json?
  beforeState Json?    @map("before_state")
  afterState Json?     @map("after_state")
  createdAt  DateTime  @default(now()) @map("created_at")
  actorUser  User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model OutboxEvent {
  id            String      @id @default(uuid()) @db.Uuid
  eventType     String      @map("event_type")
  aggregateType String      @map("aggregate_type")
  aggregateId   String      @map("aggregate_id")
  payload       Json
  status        OutboxStatus @default(PENDING)
  retryCount    Int         @default(0) @map("retry_count")
  availableAt   DateTime    @default(now()) @map("available_at")
  processedAt   DateTime?   @map("processed_at")
  lastError     String?     @map("last_error")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model MediaUploadIntent {
  id           String       @id @default(uuid()) @db.Uuid
  uploaderUserId String     @map("uploader_user_id") @db.Uuid
  target       UploadTarget
  targetId     String?      @map("target_id")
  objectKey    String       @unique @map("object_key")
  mimeType     String       @map("mime_type")
  sizeBytes    Int          @map("size_bytes")
  status       String       @default("pending")
  expiresAt    DateTime     @map("expires_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  uploader     User         @relation(fields: [uploaderUserId], references: [id], onDelete: Cascade)

  @@index([uploaderUserId, createdAt])
  @@index([target, targetId])
  @@map("media_upload_intents")
}
